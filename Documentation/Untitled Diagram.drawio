        <mxCell id="OUFKRDh82zm_G1eilYV_-9" value="+ dataLanguage: DataLanguage" style="text;strokeColor=#6F0000;fillColor=#a20025;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontColor=#ffffff;" parent="09urpwTv1l5aZDUb69TC-8" vertex="1">
