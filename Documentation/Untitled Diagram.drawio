        <mxCell id="_xIGhwf06N57o5FfxAGR-0" value="&lt;h1&gt;Tipos de Link&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Apresentaçao Documento.&lt;/li&gt;&lt;li&gt;Download Arquivo.&lt;/li&gt;&lt;li&gt;Artigo Web.&lt;/li&gt;&lt;li&gt;Apresentação Video&lt;/li&gt;&lt;li&gt;Streaming&lt;/li&gt;&lt;li&gt;Outro&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="40" y="1300" width="230" height="150" as="geometry" />
        </mxCell>
        <mxCell id="AgvWWMT_7Wn3kUDTp6G8-0" value="&lt;h1&gt;Próximos Passos&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;Fazer a descrição todas as tabelas&lt;/li&gt;&lt;li&gt;Revisar Relacionamentos no modelo conceitual&lt;/li&gt;&lt;li&gt;Criar o UML de usuário.&lt;/li&gt;&lt;li&gt;Definir elementos da constante Proof.&lt;/li&gt;&lt;li&gt;Revisar os requisitos não funcionais.&lt;/li&gt;&lt;li&gt;Criar as tabelas do banco de dados.&lt;/li&gt;&lt;li&gt;Terminar de traduzir os diagramas para o ingles&lt;/li&gt;&lt;li&gt;Definir o Numero de Caracteres no campo descrição do Santo.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="1810" y="464" width="360" height="420" as="geometry" />
        </mxCell>
