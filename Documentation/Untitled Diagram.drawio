          <mxGeometry x="1855" y="190" width="115" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KqPjWX4bO6jBrvQfZukE-6" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="1825" y="155" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="KqPjWX4bO6jBrvQfZukE-7" value="Campos Obrigatórios Sem Relacionamento" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="1855" y="150" width="235" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KqPjWX4bO6jBrvQfZukE-8" value="&lt;h1&gt;Date as String&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;As datas são definidas como string pois os registros podem estar sujeitos a datas sem mês ou dia.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="40" y="1840" width="230" height="150" as="geometry" />
        </mxCell>
        <mxCell id="KqPjWX4bO6jBrvQfZukE-9" value="&lt;h1&gt;Date &amp;amp; Time Format&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Define o formato de hora e data visto que a api pode conter registros escritos em mais de um idioma.&lt;/li&gt;&lt;li&gt;É uma constante e os registros devem ser inseridos com seed no banco.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="40" y="2000" width="250" height="150" as="geometry" />
        </mxCell>
        <mxCell id="e5xbKcEYMN-L0HG2Lrjg-0" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#6a00ff;strokeColor=#3700CC;fontColor=#ffffff;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="1825" y="235" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="e5xbKcEYMN-L0HG2Lrjg-1" value="Constants" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="1855" y="230" width="115" height="30" as="geometry" />
        </mxCell>
        <mxCell id="91ERTPKN6yuSIgdbeV36-0" value="&lt;h1&gt;Proof&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Possui uma relação &lt;b&gt;1 para Muitos &lt;/b&gt;com APIElement.&lt;/li&gt;&lt;li&gt;Uma APIElement pode estar presente em &lt;b&gt;N &lt;/b&gt;Proof&#39;s, mas uma proof só pode possuir apenas 1 API Element.&lt;/li&gt;&lt;li&gt;ElementID representa o id do registro na tabela especificada pelo API Element&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;i&gt;Isto porque uma frase pode ser provada tanto em uma obra como em um relato.&lt;/i&gt;&lt;/div&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="40" y="2200" width="230" height="230" as="geometry" />
        </mxCell>
        <mxCell id="-0MWqWbtvTPasXppajYP-0" value="&lt;h1&gt;Saint&lt;/h1&gt;&lt;div&gt;É a entidade que representa o santo na api. É o objeto principal da aplicação. Todo os outros elemento da aplicação se originam desta entidade.&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Name&lt;/b&gt;, history, e description são campos obrigatórios.&lt;/li&gt;&lt;li&gt;&lt;b&gt;History&lt;/b&gt; deve ser um campo Sem uma quantidade de textos definida e preparado para receber uma longa cadeia de caracteres.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Description&lt;/b&gt; representa uma &lt;b&gt;BREVE&lt;/b&gt; descrição do santo e deve ter no máximo XXX caracteres.&lt;/li&gt;&lt;li&gt;&lt;b&gt;birthDate/deathDate&lt;/b&gt; podem não existir ou não serem exatos por isso a data deve ser armazenada no formato de texto.&lt;/li&gt;&lt;li&gt;&lt;b&gt;DateFormat&lt;/b&gt; representa o formato em que a datas será armazenada em seus devidos campos . &lt;i&gt;(Isso por que a api é desenvolvida para suportar multiplos idiomas)&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;DataLanguage &lt;/b&gt;representa o idioma em que foram escritas as informações do registro. &lt;i&gt;(é um relacionamento 1 ... 1 com a tabela DataLanguage)&lt;/i&gt;.&lt;/li&gt;&lt;li&gt;&lt;b&gt;NativePlace &lt;/b&gt;representa o local de origem do santo. É uma informação não obrigatória. &lt;i&gt;(é um relacionamento 1...1 com a tabela NativePlace)&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Quotes&lt;/b&gt; são as frases ditas pelo santo. É uma informação não obrigatória.&lt;i&gt; (É um relacionamento 1...1 com a tabela quotes).&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;VisitedLocations&lt;/b&gt;&lt;b style=&quot;font-style: italic&quot;&gt; &lt;/b&gt;representa os lugares por onde é santo passou. É uma informação não obrigatória.&lt;i&gt; (É um relacionamento 1...1 com a tabela Location)&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Accounts &lt;/b&gt;representa os relatos históricos sobre o santo. É uma informação não obrigatória. &lt;i&gt;(É um relacionamento 1...* com a tabela Account)&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Artifacts &lt;/b&gt;representa as obras ou paticipações em o realizadas pelo santo durante sua vida. É uma informação não obrigatória. &lt;i&gt;(É um relacionamento 1...* com a tabela Artifacts).&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;ComemorativeDay - &lt;/b&gt;É a propriedade que armazema o dia comemorativo daquele santo.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Merit - &lt;/b&gt;São os titulos atribuidos àquele santo &lt;i&gt;(Doutor da igreja Padroeiro etc). &lt;/i&gt;É uma relação com outra tabela que serve como constante.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="40" y="2470" width="580" height="460" as="geometry" />
        </mxCell>
        <mxCell id="1khy3ZHIb4Vb0B1TcLc5-1" value="Merit" style="swimlane;fontStyle=1;childLayout=stackLayout;horizontal=1;startSize=26;fillColor=#6a00ff;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;strokeColor=#3700CC;fontColor=#ffffff;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="760" y="760" width="140" height="78" as="geometry" />
        </mxCell>
        <mxCell id="JQl29CMttDa4p2Vrh7ZS-0" value="+ constantNumber: Int" style="text;strokeColor=#6D1F00;fillColor=#a0522d;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontColor=#ffffff;" parent="1khy3ZHIb4Vb0B1TcLc5-1" vertex="1">
          <mxGeometry y="26" width="140" height="26" as="geometry" />
        </mxCell>
        <mxCell id="1khy3ZHIb4Vb0B1TcLc5-3" value="+ title: String" style="text;strokeColor=#6D1F00;fillColor=#a0522d;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontColor=#ffffff;" parent="1khy3ZHIb4Vb0B1TcLc5-1" vertex="1">
          <mxGeometry y="52" width="140" height="26" as="geometry" />
        </mxCell>
        <mxCell id="riDKCrU4xLwdBZOYYJ-i-3" value="&lt;h1&gt;Artifact&lt;/h1&gt;&lt;div&gt;É a entidade que representa todo o artefato, ou seja, pedaços de informação referentes a um santo ou obra, os artefatos podem ser de vários tipos &lt;i&gt;(arquivos, links, textos, videos, imagens etc)&lt;/i&gt;. A tabela, juntamente com as suas outras relações devem possibilitar a flexibilidade necessária para que todo o tipo de Artefato &lt;i&gt;(informação)&lt;/i&gt;&amp;nbsp;seja inserido.&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Name - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;é o nome dado para o artefato.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Description - &lt;/b&gt;&lt;i&gt;(&lt;/i&gt;&lt;i&gt;campo obrigatório)&lt;/i&gt; representa uma&amp;nbsp;&lt;b&gt;BREVE&lt;/b&gt;&amp;nbsp;descrição do artefato e deve ter no máximo XXX caracteres.&lt;/li&gt;&lt;li&gt;&lt;b&gt;History&lt;/b&gt;&amp;nbsp;- &lt;i&gt;(campo obrigatório) &lt;/i&gt;Representa a história daquele artefato.&lt;/li&gt;&lt;li&gt;&lt;b&gt;URL - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;É o link que da acesso ao artefato propriamente dito.&lt;/li&gt;&lt;li&gt;&lt;b&gt;ArtifactType - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;É&amp;nbsp;a constate que representa o tipo de artefato &lt;i&gt;(artigo, video, documento, imagem, outro etc).&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;LinkType - &lt;/b&gt;&lt;i&gt;(campo obrigatóio) &lt;/i&gt;É&amp;nbsp;o tipo de link artefato&lt;i&gt; (download, pagina html simples etc).&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;DataLanguage &lt;/b&gt;&lt;span&gt;representa o idioma em que foram escritas as informações do registro. &lt;/span&gt;&lt;i&gt;(é um relacionamento 1 ... 1 com a tabela DataLanguage)&lt;/i&gt;&lt;span&gt;.&lt;/span&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="910" y="2470" width="580" height="320" as="geometry" />
        </mxCell>
        <mxCell id="bDw_Y36mICLTyopFe_rI-0" value="&lt;h1&gt;Work&lt;/h1&gt;&lt;div&gt;É a entidade que representa toda obra realizada por um santo.&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Title - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;é o título ou nome da obra.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Creation Date - &lt;/b&gt;Armazena a Data em que a obra foi Criada, não é um campo obrigatório pois podem existir obras em que não seja possível saber a data exata de criação, é preciso ser acompanhada do campo date format&lt;b&gt;.&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Creation Time&lt;/b&gt;&amp;nbsp;- &lt;i&gt;&amp;nbsp;&lt;/i&gt;Armazena a Hora em que a obra foi Criada, não é um campo obrigatório pois podem existir obras em que não seja possível saber a hora exata de criação, é preciso ser acompanhada do campo time format.&lt;/li&gt;&lt;li&gt;&lt;b&gt;History - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;É o campo que armazena toda a história acerca daquela obra.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Description - &lt;/b&gt;&lt;i&gt;(campo obrigatório)&amp;nbsp;&lt;/i&gt;representa uma&amp;nbsp;&lt;b&gt;BREVE&lt;/b&gt;&amp;nbsp;descrição da obra e deve ter no máximo XXX caracteres.&lt;/li&gt;&lt;li&gt;&lt;b&gt;DataLanguage &lt;/b&gt;&lt;i&gt;(campo obrigatório)&lt;b&gt; -&amp;nbsp;&lt;/b&gt;&lt;/i&gt;&lt;span&gt;representa o idioma em que foram escritas as informações do registro. &lt;/span&gt;&lt;i&gt;(é um relacionamento 1 ... 1 com a tabela DataLanguage),&amp;nbsp;&lt;/i&gt;&lt;span&gt;É preciso ser preenchido com um valor padrão caso não seja armazenada nenhuma hora.&lt;/span&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;DateFormat &lt;/b&gt;&lt;i&gt;(campo obrigatório) - &lt;/i&gt;É um campo de texto que define o formato das datas armazenadas para o registro de uma obra. &lt;i&gt;(É um campo necessário visto que não existe exatidão de datas podendo haver informações faltantes como dia, mês e ano),&amp;nbsp;&lt;/i&gt;É preciso ser preenchido com um valor padrão caso não seja armazenada nenhuma data&lt;i&gt;.&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;TimeFormat &lt;/b&gt;&lt;i&gt;(campo obrigatório)&amp;nbsp;&lt;/i&gt;&lt;i&gt;-&amp;nbsp;&lt;/i&gt;É um campo de texto que define o formato das horas armazenadas para o registro de uma obra.&amp;nbsp;&lt;i&gt;(É um campo necessário visto que em alguns países podemos ter a definição am/pm ou 24h).&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Native Place - &lt;/b&gt;É o campo que define o local de origem daquela obra. &lt;i&gt;(É um relacionamento &lt;b&gt;1..1 &lt;/b&gt;com a tabela Native Place).&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Artifacts - &lt;/b&gt;São todos os artefatos existentes acerca de uma obra. &lt;i&gt;(É uma lista &lt;b&gt;1...*&lt;/b&gt; com a tabela artifacts).&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Accounts - &lt;/b&gt;São todos os relatos existentes acerca de uma obra.&amp;nbsp;&lt;i&gt;(É um relacionamento &lt;b&gt;1...* &lt;/b&gt;com a tabela accounts).&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Visited Locations - &lt;/b&gt;Armazena informações sobre os locais onde aquela obra esteve presente.&amp;nbsp;&lt;i&gt;(É um relacionamento&amp;nbsp;&lt;b&gt;1...*&amp;nbsp;&lt;/b&gt;com a tabela Location).&lt;/i&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="40" y="2990" width="580" height="510" as="geometry" />
        </mxCell>
        <mxCell id="b1JsHfDIWufMkopQpaLW-0" value="&lt;h1&gt;Native Place&lt;/h1&gt;&lt;div&gt;É a entidade que representa o local do origem de um santo ou obra.&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Title - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;é o nome do lugar de origem do santo ou obra..&lt;/li&gt;&lt;li&gt;&lt;b&gt;Country - &lt;/b&gt;&lt;i&gt;(&lt;/i&gt;&lt;i&gt;campo obrigatório)&lt;/i&gt; representa o país onde se encontra o local de origem do santo ou obra.&lt;/li&gt;&lt;li&gt;&lt;b&gt;City&lt;/b&gt;&amp;nbsp;-&lt;i&gt;&amp;nbsp;&lt;/i&gt;Representa a cidade onde se encontra o local de origem do santo ou obra..&lt;/li&gt;&lt;li&gt;&lt;b&gt;Aditional Information -&lt;/b&gt;&lt;i&gt;&amp;nbsp;&lt;/i&gt;É o campo reservado para armazenar quaisquer informações adicionais sobre o local de origem do santo ou obra.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Latitude - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;É o campo que armazena a Latitude do local do origem para que o mesmo possa ser georeferenciado.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Longitude - &lt;/b&gt;&lt;i&gt;(campo obrigatóio)&amp;nbsp;&lt;/i&gt;É o campo que armazena a Longitude do local do origem para que o mesmo possa ser georeferenciado.&lt;/li&gt;&lt;li&gt;&lt;b&gt;DataLanguage -&amp;nbsp;&lt;/b&gt;&lt;span&gt;representa o idioma em que foram escritas as informações do registro. &lt;/span&gt;&lt;i&gt;(é um relacionamento 1 ... 1 com a tabela DataLanguage)&lt;/i&gt;&lt;span&gt;.&lt;/span&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Description -&amp;nbsp;&lt;/b&gt;representa uma&amp;nbsp;&lt;b&gt;BREVE&lt;/b&gt;&amp;nbsp;descrição do santo e deve ter no máximo XXX caracteres.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="900" y="2910" width="580" height="320" as="geometry" />
        </mxCell>
        <mxCell id="b1JsHfDIWufMkopQpaLW-6" value="&lt;h1&gt;Native Place&lt;/h1&gt;&lt;div&gt;É a entidade que representa o local do origem de um santo ou obra.&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Title - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;é o nome do lugar de origem do santo ou obra..&lt;/li&gt;&lt;li&gt;&lt;b&gt;Country - &lt;/b&gt;&lt;i&gt;(&lt;/i&gt;&lt;i&gt;campo obrigatório)&lt;/i&gt; representa o país onde se encontra o local de origem do santo ou obra.&lt;/li&gt;&lt;li&gt;&lt;b&gt;City&lt;/b&gt;&amp;nbsp;-&lt;i&gt;&amp;nbsp;&lt;/i&gt;Representa a cidade onde se encontra o local de origem do santo ou obra..&lt;/li&gt;&lt;li&gt;&lt;b&gt;Aditional Information -&lt;/b&gt;&lt;i&gt;&amp;nbsp;&lt;/i&gt;É o campo reservado para armazenar quaisquer informações adicionais sobre o local de origem do santo ou obra.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Latitude - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;É o campo que armazena a Latitude do local do origem para que o mesmo possa ser georeferenciado.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Longitude - &lt;/b&gt;&lt;i&gt;(campo obrigatóio)&amp;nbsp;&lt;/i&gt;É o campo que armazena a Longitude do local do origem para que o mesmo possa ser georeferenciado.&lt;/li&gt;&lt;li&gt;&lt;b&gt;DataLanguage &lt;/b&gt;&lt;span&gt;representa o idioma em que foram escritas as informações do registro. &lt;/span&gt;&lt;i&gt;(é um relacionamento 1 ... 1 com a tabela DataLanguage)&lt;/i&gt;&lt;span&gt;.&lt;/span&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="2060" y="6190" width="580" height="320" as="geometry" />
        </mxCell>
        <mxCell id="b1JsHfDIWufMkopQpaLW-7" value="&lt;h1&gt;Quote&lt;/h1&gt;&lt;div&gt;É a entidade que representa as palavras de autoria de um santo.&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Quote - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;É a palavra proferida por um santo.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Description - &lt;/b&gt;Armazena mais informações sobre a palavra do santo.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Proofs - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;É a referência de onde o dito se originou&amp;nbsp;&lt;i&gt;(É um relacionamento&amp;nbsp;&lt;b&gt;1...*&amp;nbsp;&lt;/b&gt;com a tabela Proof).&lt;/i&gt;.&lt;/li&gt;&lt;li&gt;&lt;b&gt;DataLanguage &lt;/b&gt;&lt;span&gt;representa o idioma em que foram escritas as informações do registro. &lt;/span&gt;&lt;i&gt;(é um relacionamento 1 ... 1 com a tabela DataLanguage)&lt;/i&gt;&lt;span&gt;.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="900" y="3300" width="580" height="320" as="geometry" />
        </mxCell>
        <mxCell id="b1JsHfDIWufMkopQpaLW-8" value="&lt;h1&gt;Account&lt;/h1&gt;&lt;div&gt;É a entidade que representa um relato sobre um sant&lt;span&gt;o ou obra.&lt;/span&gt;&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Title - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;é o título que da nome ao relato &lt;i&gt;(Deve ser semântico)&lt;/i&gt;.&lt;/li&gt;&lt;li&gt;&lt;b&gt;History&amp;nbsp;&lt;i style=&quot;font-weight: 400&quot;&gt;(campo obrigatório)&amp;nbsp;&lt;/i&gt;- &lt;/b&gt;É a historia completa do relato.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Reference&lt;/b&gt;&amp;nbsp;- &lt;i&gt;&amp;nbsp;&lt;/i&gt;Pode-se colocar as referências do relato aqui é uma única descrição caso estas existam.&lt;/li&gt;&lt;li&gt;&lt;b&gt;HappeningDate - &lt;/b&gt;&lt;i&gt;&amp;nbsp;&lt;/i&gt;É o campo que armazena a data de acontecimento do fato relatado.&lt;/li&gt;&lt;li&gt;&lt;b&gt;HappeningTime - &lt;/b&gt;É o campo que armazena a hora de acontecimento do fato relatado.&lt;/li&gt;&lt;li&gt;&lt;b&gt;DateFormat &lt;/b&gt;&lt;i&gt;(campo obrigatório) - &lt;/i&gt;&lt;span&gt;É um campo de texto que define o formato das datas armazenadas para o registro de uma obra. &lt;/span&gt;&lt;i&gt;(É um campo necessário visto que não existe exatidão de datas podendo haver informações faltantes como dia, mês e ano),&amp;nbsp;&lt;/i&gt;&lt;span&gt;É preciso ser preenchido com um valor padrão caso não seja armazenada nenhuma data&lt;/span&gt;&lt;i&gt;.&lt;/i&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;TimeFormat &lt;/b&gt;&lt;i&gt;(campo obrigatório)&amp;nbsp;&lt;/i&gt;&lt;i&gt;-&amp;nbsp;&lt;/i&gt;É um campo de texto que define o formato das horas armazenadas para o registro de uma obra.&amp;nbsp;&lt;i&gt;(É um campo necessário visto que em alguns países podemos ter a definição am/pm ou 24h).&lt;/i&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;DataLanguage&amp;nbsp;&lt;/b&gt;&lt;i&gt;(campo obrigatório)&lt;b&gt;&amp;nbsp;-&amp;nbsp;&lt;/b&gt;&lt;/i&gt;representa o idioma em que foram escritas as informações do registro.&amp;nbsp;&lt;i&gt;(é um relacionamento 1 ... 1 com a tabela DataLanguage),&amp;nbsp;&lt;/i&gt;É preciso ser preenchido com um valor padrão caso não seja armazenada nenhuma lingua.&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="80" y="3600" width="580" height="510" as="geometry" />
        </mxCell>
        <mxCell id="3Z6brV3u3WYfHr0Phxgi-0" value="&lt;h1&gt;Location&lt;/h1&gt;&lt;div&gt;É a entidade que representa as palavras de autoria de um santo.&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Title - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;É a palavra proferida por um santo.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Description - &lt;/b&gt;Descriçao da localização, Limitado em XXX caracteres.&lt;/li&gt;&lt;li&gt;&lt;b&gt;History -&lt;/b&gt;&amp;nbsp;Historia da localização, é importante enfatizar as alterações politicas globais que acontecem ao decorrer da História.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Latitude - &lt;/b&gt;&lt;i&gt;(campo obrigatório) &lt;/i&gt;Latitude no geo referenciamento&lt;/li&gt;&lt;li&gt;&lt;b&gt;Longitude -&lt;/b&gt;&amp;nbsp;&lt;i&gt;(campo obrigatório)&amp;nbsp;&lt;/i&gt;Longitude no geo referenciamento&lt;/li&gt;&lt;li&gt;&lt;b&gt;DataLanguage &lt;/b&gt;&lt;span&gt;representa o idioma em que foram escritas as informações do registro. &lt;/span&gt;&lt;i&gt;(é um relacionamento 1 ... 1 com a tabela DataLanguage)&lt;/i&gt;&lt;span&gt;.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="i770FoSl32qIDSlJSuP9-1">
          <mxGeometry x="990" y="3540" width="580" height="320" as="geometry" />
        </mxCell>
        <mxCell id="3Z6brV3u3WYfHr0Phxgi-9" value="Location" style="swimlane;fontStyle=1;childLayout=stackLayout;horizontal=1;startSize=26;fillColor=#ffe6cc;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;strokeColor=#d79b00;" vertex="1" parent="i770FoSl32qIDSlJSuP9-1">
