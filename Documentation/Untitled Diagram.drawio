        </mxCell>
        <mxCell id="0Q3cdzsVPUSM3lw-nP6h-0" value="&lt;h1&gt;Explicação&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Location&lt;/b&gt; - É a lista de lugares onde o santo ou obra estão ou estiveram presentes.&lt;/li&gt;&lt;/ul&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Accounts&lt;/b&gt; - São os relatos históricos sobre o santo ou obra.&lt;/li&gt;&lt;/ul&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Artifacts&lt;/b&gt; - São os documentos do santo ou obra fornecidos pela api em forma de documentos digitais (videos, página web, links, pdf etc).&lt;/li&gt;&lt;/ul&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Proof - &lt;/b&gt;&lt;i&gt;É usado para referenciar uma informação Inserida na API baseado em algum elemento existente.&lt;/i&gt; &lt;i&gt;Ex: (A frase de um santo pode ser provada em alguma obra ou relato). Isso dificulta a inserção de informações falsas ou duvidosas&lt;/i&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="1690" y="1090" width="360" height="420" as="geometry" />
        </mxCell>
        <mxCell id="0Q3cdzsVPUSM3lw-nP6h-1" value="&lt;h1&gt;Quotes&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Uma frase deve possuir no mínimo uma prova &lt;i&gt;(Proof)&lt;/i&gt;&amp;nbsp;obrigatóriamente.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="i770FoSl32qIDSlJSuP9-1" vertex="1">
          <mxGeometry x="40" y="1480" width="230" height="150" as="geometry" />
        </mxCell>
